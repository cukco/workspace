{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build ARM64",
      "type": "shell",
      "command": "as -o ${fileBasenameNoExtension}.o ${file} && ld -o ${fileBasenameNoExtension} ${fileBasenameNoExtension}.o -lSystem -syslibroot `xcrun -sdk macosx --show-sdk-path` -e _main -arch arm64",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "C/C++: clang build active file",
      "type": "shell",
      "command": "/usr/bin/clang++",
      "args": [
        "-fdiagnostics-color=always",
        "-g",
        "${file}",
        "-o",
        "${fileDirname}/${fileBasenameNoExtension}"
      ],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "detail": "Trình biên dịch mặc định trên macOS"
    }
  ]
}
